// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}
筋
model Post {
  id              String   @id @default(cuid())
  platform        String
  externalId      String   @unique
  authorName      String
  authorUrl       String
  text            String
  postUrl         String   @unique
  postedAt        DateTime
  engagement      String?  // JSON stringified engagement metrics
  matchedTerms    String   // Comma-separated search terms
  matchedKeywords String?  // Comma-separated matched niche keywords
  relevanceScore  Int      @default(0)
  priority        String   @default("Low") // High, Medium, Low
  isUrgent        Boolean  @default(false)
  hasDeadline     Boolean  @default(false)
  isJournalist    Boolean  @default(false)
  isSent          Boolean  @default(false)
  sentAt          DateTime?
  discoveredAt    DateTime @default(now())

  @@index([platform])
  @@index([priority])
  @@index([isSent])
}

model SearchTerm {
  id        String   @id @default(cuid())
  term      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model NicheKeyword {
  id        String   @id @default(cuid())
  keyword   String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model RunLog {
  id             String   @id @default(cuid())
  startTime      DateTime @default(now())
  endTime        DateTime?
  status         String   // SUCCESS, FAILURE
  resultsFound   Int      @default(0)
  resultsEmailed Int      @default(0)
  errorMessage   String?
}
